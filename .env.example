# app
APP_NAME=格物学术
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_FILE_ENABLED=true
LOG_FILE_MAX_MB=20
LOG_FILE_BACKUP_COUNT=7
LOG_DIRNAME=logs
JWT_SECRET=change_me_in_prod
JWT_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax
USER_REFRESH_COOKIE_NAME=gw_user_refresh
ADMIN_REFRESH_COOKIE_NAME=gw_admin_refresh
DATA_ENCRYPTION_KEY=change_me_data_key

# db
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=wuhongai
SQLITE_PATH=wuhongai.db
DB_FALLBACK_SQLITE=true

# redis / celery
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# business
INITIAL_CREDITS=5000
REFERRAL_REGISTER_INVITER_CREDITS=500
REFERRAL_REGISTER_INVITEE_BONUS=500
MAX_CODE_RETRY=3
PHONE_LOCK_MINUTES=5
AUTH_SEND_CODE_IP_1H_LIMIT=30
AUTH_LOGIN_IP_10M_LIMIT=120
AUTH_RETURN_DEBUG_CODE=false
ADMIN_LOGIN_IP_ALLOWLIST=
SMS_API_KEY=
SMS_GATEWAY_URL=
PAYMENT_SIGN_SECRET=change_me_payment_sign_key
PAYMENT_CALLBACK_TTL_SECONDS=900
PAYMENT_TEST_MODE=true
FRONTEND_BASE_URL=http://localhost:5173
ALGORITHM_PACKAGE_ROOT=
ALGORITHM_PACKAGE_MAX_MB=200
DOCX_PROCESS_TABLE_TEXT=true
LLM_ENABLED_DEFAULT=false
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=25
LLM_RETRY_ATTEMPTS=3
LLM_RETRY_BACKOFF_BASE_SECONDS=0.8
DB_CONNECT_TIMEOUT_SECONDS=10
DB_READ_TIMEOUT_SECONDS=30
DB_WRITE_TIMEOUT_SECONDS=30
DB_STATEMENT_TIMEOUT_MS=30000
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400

# frontend
VITE_API_BASE_URL=http://localhost:8000/api/v1
VITE_ENABLE_WECHAT_LOGIN=false
VITE_PAYMENT_TEST_MODE=true
