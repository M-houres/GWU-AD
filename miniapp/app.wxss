/* Visual language
 * Canvas:          #f4f8ff
 * Paper:           #ffffff
 * Paper soft:      #f8fbff
 * Brand blue:      #1e5bdf
 * Brand blue deep: #184ec8
 * Ink:             #17385f
 * Ink soft:        #627a95
 * Radius:          16 / 20 / 24 / 28
 */

page {
  min-height: 100%;
  background: linear-gradient(180deg, #f8fbff 0%, #edf4ff 180rpx, #f4f8ff 180rpx, #f4f8ff 100%);
  color: #17385f;
  font-size: 22rpx;
  line-height: 1.64;
  font-family: "PingFang SC", "HarmonyOS Sans SC", "Microsoft YaHei", sans-serif;
  letter-spacing: 0.04rpx;
}

view,
text,
button,
input,
image,
scroll-view {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  border: none;
  line-height: 1.2;
  background: transparent;
  font-size: 22rpx;
}

button::after {
  border: none;
}

input {
  width: 100%;
  font-size: 22rpx;
}

.page-shell {
  min-height: 100vh;
  padding: 24rpx 20rpx 108rpx;
}

.page-shell--center {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.content-stack {
  position: relative;
}

.hero-panel {
  padding: 34rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.98);
  color: #17385f;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
  box-shadow: 0 10rpx 24rpx rgba(30, 91, 223, 0.08);
}

.hero-panel--light {
  background: rgba(248, 251, 255, 0.98);
}

.eyebrow {
  font-size: 17rpx;
  letter-spacing: 1.2rpx;
  color: #1e5bdf;
  font-weight: 600;
}

.hero-title {
  margin-top: 12rpx;
  font-size: 34rpx;
  line-height: 1.18;
  font-weight: 700;
  color: #17385f;
}

.hero-subtitle {
  margin-top: 12rpx;
  font-size: 18rpx;
  line-height: 1.62;
  color: #627a95;
}

.hero-meta {
  display: flex;
  flex-wrap: wrap;
  margin: 18rpx -6rpx 0;
}

.hero-chip {
  margin: 6rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(30, 91, 223, 0.08);
  border: 1.5rpx solid rgba(30, 91, 223, 0.14);
  color: #1e5bdf;
  font-size: 17rpx;
  font-weight: 600;
}

.hero-panel--light .hero-chip {
  background: rgba(30, 91, 223, 0.06);
  border-color: rgba(30, 91, 223, 0.12);
  color: #1e5bdf;
}

.surface {
  margin-top: 20rpx;
  padding: 26rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
  box-shadow: 0 8rpx 18rpx rgba(30, 91, 223, 0.06);
}

.surface--soft {
  background: #ffffff;
}

.surface--accent {
  background: #ffffff;
}

.surface--compact {
  padding: 22rpx;
}

.section-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.section-copy {
  flex: 1;
  padding-right: 20rpx;
}

.section-kicker {
  font-size: 17rpx;
  color: #1e5bdf;
  letter-spacing: 1.2rpx;
  font-weight: 600;
}

.section-title {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.28;
  font-weight: 700;
  color: #17385f;
}

.section-desc {
  margin-top: 10rpx;
  font-size: 18rpx;
  line-height: 1.66;
  color: #627a95;
}

.plain-tag,
.warm-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  font-size: 18rpx;
  font-weight: 600;
}

.plain-tag {
  background: rgba(30, 91, 223, 0.12);
  color: #1e5bdf;
}

.warm-tag {
  background: rgba(30, 91, 223, 0.16);
  color: #184ec8;
}

.info-strip {
  margin-top: 18rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
}

.info-strip--warm {
  background: #ffffff;
  border-color: rgba(30, 91, 223, 0.16);
}

.info-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #17385f;
}

.info-desc {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.62;
  color: #627a95;
}

.feature-list {
  margin-top: 12rpx;
}

.feature-item + .feature-item {
  margin-top: 16rpx;
}

.list-title {
  font-size: 22rpx;
  line-height: 1.35;
  font-weight: 700;
  color: #17385f;
}

.list-subtitle {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.62;
  color: #627a95;
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  margin: 18rpx -6rpx 0;
}

.meta-pill {
  margin: 6rpx;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(248, 251, 255, 0.96);
  border: 1.5rpx solid rgba(30, 91, 223, 0.14);
  color: #6d83a0;
  font-size: 18rpx;
}

.step-flow {
  display: flex;
  flex-wrap: wrap;
  margin: 14rpx -8rpx 0;
}

.step-item {
  flex: 1 1 300rpx;
  margin: 8rpx;
  padding: 20rpx 18rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
}

.step-no {
  width: 40rpx;
  height: 40rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #6ca0ff 0%, #4584fa 38%, #1e5bdf 100%);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  box-shadow: 0 6rpx 14rpx rgba(30, 91, 223, 0.2);
}

.step-title {
  margin-top: 14rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #17385f;
}

.step-desc {
  margin-top: 8rpx;
  font-size: 17rpx;
  line-height: 1.58;
  color: #6c819b;
}

.option-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 16rpx -8rpx 0;
}

.option-card {
  flex: 1 1 300rpx;
  position: relative;
  margin: 8rpx;
  min-height: 188rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
  box-shadow: 0 8rpx 18rpx rgba(30, 91, 223, 0.06);
  transition: transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease, background 180ms ease;
}

.option-card.active {
  background: linear-gradient(180deg, #6ca0ff 0%, #4584fa 38%, #1e5bdf 100%);
  border-color: rgba(30, 91, 223, 0.34);
  box-shadow: 0 10rpx 22rpx rgba(30, 91, 223, 0.2);
}

.option-eyebrow {
  display: inline-flex;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(30, 91, 223, 0.12);
  color: #1e5bdf;
  font-size: 17rpx;
}

.option-title {
  margin-top: 16rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #17385f;
}

.option-desc {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.6;
  color: #627a95;
}

.option-note {
  margin-top: 14rpx;
  font-size: 17rpx;
  color: #1e5bdf;
}

.segment-row {
  display: flex;
  flex-wrap: wrap;
  margin: 16rpx -8rpx 0;
}

.segment-chip {
  margin: 8rpx;
  min-height: 68rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
  color: #69809a;
  font-size: 19rpx;
  font-weight: 600;
  transition: transform 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.segment-chip.active {
  background: linear-gradient(180deg, #6ca0ff 0%, #4584fa 38%, #1e5bdf 100%);
  border-color: rgba(30, 91, 223, 0.34);
  color: #ffffff;
  box-shadow: 0 10rpx 20rpx rgba(30, 91, 223, 0.18);
}

.field {
  margin-top: 22rpx;
}

.field:first-child {
  margin-top: 0;
}

.field-label {
  margin-bottom: 12rpx;
  font-size: 18rpx;
  font-weight: 600;
  color: #6e84a0;
}

.text-input {
  min-height: 84rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
  background: #ffffff;
  color: #17385f;
  box-shadow: none;
  transition: border-color 160ms ease, box-shadow 160ms ease, background 160ms ease;
}

.helper-text {
  margin-top: 12rpx;
  font-size: 17rpx;
  line-height: 1.62;
  color: #6c819b;
}

.upload-box {
  margin-top: 20rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx dashed rgba(30, 91, 223, 0.28);
  box-shadow: none;
}

.upload-label {
  font-size: 17rpx;
  color: #7b90ab;
}

.upload-file {
  margin-top: 12rpx;
  font-size: 21rpx;
  line-height: 1.46;
  color: #17385f;
  font-weight: 700;
}

.button-group {
  display: flex;
  flex-wrap: wrap;
  margin: 24rpx -8rpx 0;
}

.button-item {
  flex: 1 1 240rpx;
  margin: 8rpx;
}

.primary-btn,
.secondary-btn,
.ghost-btn {
  width: 100%;
  min-height: 78rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 700;
  transition: transform 160ms ease, box-shadow 160ms ease, opacity 160ms ease, background 160ms ease;
}

.primary-btn {
  background: linear-gradient(180deg, #6ca0ff 0%, #4584fa 38%, #1e5bdf 100%);
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(30, 91, 223, 0.18);
}

.secondary-btn {
  background: #ffffff;
  color: #17385f;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
  box-shadow: none;
}

.ghost-btn {
  background: #ffffff;
  color: #17385f;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
}

.primary-btn[disabled],
.secondary-btn[disabled],
.ghost-btn[disabled] {
  opacity: 0.52;
  filter: saturate(0.68);
  box-shadow: none;
}

.status-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  font-size: 19rpx;
  font-weight: 700;
  letter-spacing: 0.5rpx;
  border: 1rpx solid transparent;
}

.status-pending {
  background: rgba(233, 240, 251, 0.92);
  border-color: rgba(115, 145, 187, 0.24);
  color: #6c819b;
}

.status-running {
  background: rgba(30, 91, 223, 0.12);
  border-color: rgba(30, 91, 223, 0.2);
  color: #1e5bdf;
}

.status-completed {
  background: rgba(30, 91, 223, 0.1);
  border-color: rgba(30, 91, 223, 0.18);
  color: #1e5bdf;
}

.status-failed {
  background: rgba(191, 66, 70, 0.14);
  border-color: rgba(191, 66, 70, 0.24);
  color: #9c1f26;
}

.status-closed {
  background: rgba(235, 242, 252, 0.92);
  border-color: rgba(126, 153, 192, 0.24);
  color: #6d83a0;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  margin: 18rpx -6rpx 0;
}

.filter-pill {
  margin: 6rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1.5rpx solid rgba(30, 91, 223, 0.14);
  color: #6d83a0;
  font-size: 18rpx;
  transition: transform 160ms ease, background 160ms ease, box-shadow 160ms ease;
}

.filter-pill.active {
  background: rgba(239, 245, 255, 0.98);
  color: #1e5bdf;
  box-shadow: 0 0 0 3rpx rgba(30, 91, 223, 0.1);
}

.filter-count {
  margin-left: 10rpx;
  opacity: 0.82;
}

.stat-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 20rpx -8rpx 0;
}

.stat-card {
  flex: 1 1 280rpx;
  margin: 8rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
}

.stat-label {
  font-size: 18rpx;
  color: #7187a2;
}

.stat-value {
  margin-top: 12rpx;
  font-size: 28rpx;
  line-height: 1.2;
  font-weight: 700;
  color: #17385f;
}

.stat-desc {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.58;
  color: #627a95;
}

.record-metrics,
.report-grid {
  display: flex;
  flex-wrap: wrap;
  margin: 18rpx -6rpx 0;
}

.metric-item,
.report-card {
  flex: 1 1 200rpx;
  margin: 6rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
}

.metric-label,
.report-label {
  font-size: 17rpx;
  color: #7187a2;
}

.metric-value,
.report-value {
  margin-top: 8rpx;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 700;
  color: #17385f;
}

.kv-list {
  margin-top: 10rpx;
}

.kv-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid rgba(30, 91, 223, 0.08);
}

.kv-item:last-child {
  padding-bottom: 0;
  border-bottom: none;
}

.kv-label {
  font-size: 17rpx;
  color: #6d83a0;
}

.kv-value {
  max-width: 62%;
  text-align: right;
  font-size: 19rpx;
  line-height: 1.48;
  color: #17385f;
  font-weight: 600;
  word-break: break-all;
}

.notice-copy,
.pre-text {
  font-size: 18rpx;
  line-height: 1.68;
  color: #627a95;
  white-space: pre-wrap;
}

.empty-state {
  padding: 48rpx 24rpx;
  border-radius: 24rpx;
  border: 2rpx dashed rgba(30, 91, 223, 0.18);
  background: #ffffff;
  text-align: center;
}

.empty-mark {
  width: 88rpx;
  height: 88rpx;
  margin: 0 auto 18rpx;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(30, 91, 223, 0.12);
  color: #1e5bdf;
  font-size: 30rpx;
  font-weight: 700;
}

.empty-title {
  font-size: 22rpx;
  font-weight: 700;
  color: #17385f;
}

.empty-desc {
  margin-top: 10rpx;
  font-size: 18rpx;
  line-height: 1.62;
  color: #6c819b;
}

.panel-gap {
  margin-top: 20rpx;
}

.muted {
  color: #7389a4;
}

.home-tap-item {
  width: 100%;
}

.loading-inline {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 6rpx 2rpx;
}

.loading-orbit {
  width: 60rpx;
  height: 60rpx;
  position: relative;
  border-radius: 30rpx;
  background: rgba(30, 91, 223, 0.1);
}

.loading-dot {
  position: absolute;
  width: 12rpx;
  height: 12rpx;
  border-radius: 6rpx;
  background: #1e5bdf;
  animation: orbitPulse 1.15s ease-in-out infinite;
}

.loading-dot--a {
  left: 24rpx;
  top: 8rpx;
}

.loading-dot--b {
  right: 8rpx;
  top: 24rpx;
  animation-delay: 0.18s;
}

.loading-dot--c {
  left: 24rpx;
  bottom: 8rpx;
  animation-delay: 0.36s;
}

.loading-copy {
  flex: 1;
  min-width: 0;
}

.loading-title {
  font-size: 22rpx;
  line-height: 1.36;
  font-weight: 700;
  color: #17385f;
}

.loading-desc {
  margin-top: 8rpx;
  font-size: 18rpx;
  line-height: 1.56;
  color: #6c819b;
}

.skeleton-row {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.skeleton-card {
  flex: 1;
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(90deg, rgba(239, 245, 255, 0.96) 25%, rgba(255, 255, 255, 1) 50%, rgba(239, 245, 255, 0.96) 75%);
  background-size: 240% 100%;
  animation: shimmerFlow 1.8s linear infinite;
}

.skeleton-line {
  height: 16rpx;
  margin-top: 14rpx;
  border-radius: 999rpx;
  background: rgba(30, 91, 223, 0.08);
}

.skeleton-line:first-child {
  margin-top: 0;
}

.skeleton-line--short {
  width: 46%;
}

.skeleton-line--mid {
  width: 74%;
}

.floating-panel {
  padding: 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(30, 91, 223, 0.14);
  box-shadow: 0 8rpx 18rpx rgba(30, 91, 223, 0.06);
}

.divider-hairline {
  height: 1rpx;
  margin: 18rpx 0;
  background: rgba(30, 91, 223, 0.08);
}

.is-press-card {
  transform: translateY(2rpx) scale(0.994);
  box-shadow: 0 8rpx 16rpx rgba(30, 91, 223, 0.08);
}

.is-press-btn {
  transform: translateY(2rpx) scale(0.992);
  opacity: 0.96;
  filter: saturate(1.04);
}

.button-hover {
  transform: translateY(2rpx) scale(0.992);
  opacity: 0.96;
  filter: saturate(1.04);
}

.is-press-pill {
  transform: scale(0.98);
  opacity: 0.97;
}

.is-press-soft {
  transform: scale(0.992);
  opacity: 0.97;
}

@keyframes orbitPulse {
  0%,
  100% {
    transform: scale(0.72);
    opacity: 0.42;
  }

  50% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes shimmerFlow {
  0% {
    background-position: 200% 0;
  }

  100% {
    background-position: -40% 0;
  }
}
