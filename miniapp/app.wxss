page {
  background: #ffffff;
  color: #111111;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
}

.card {
  border: 1px solid #e3e3e3;
  border-radius: 16rpx;
  padding: 24rpx;
  background: #ffffff;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  color: #111111;
}

.muted {
  color: #666666;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.gap-12 {
  margin-top: 12rpx;
}

.gap-16 {
  margin-top: 16rpx;
}

.gap-24 {
  margin-top: 24rpx;
}

.btn-primary {
  background: #000000;
  color: #ffffff;
  border: 1px solid #000000;
  border-radius: 12rpx;
}

.btn-secondary {
  background: #ffffff;
  color: #111111;
  border: 1px solid #111111;
  border-radius: 12rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1px solid #111111;
  background: #ffffff;
  color: #111111;
}

.chip.active {
  background: #000000;
  color: #ffffff;
}

.input {
  border: 1px solid #d9d9d9;
  border-radius: 12rpx;
  padding: 16rpx;
  background: #ffffff;
  color: #111111;
}

