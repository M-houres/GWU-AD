.page-shell--home {
  padding-top: 20rpx;
}

.page-shell--home .content-stack {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.page-shell--home .home-hero {
  padding: 34rpx 28rpx 26rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #18c96c 0%, #07c160 52%, #06b45a 100%);
  border: 2rpx solid rgba(6, 150, 76, 0.34);
  box-shadow: 0 12rpx 26rpx rgba(7, 193, 96, 0.2);
  color: #1f2329;
  animation: heroRise 420ms ease both;
}

.page-shell--home .home-hero::before {
  display: none;
}

.page-shell--home .home-hero::after {
  display: none;
}

.page-shell--home .hero-title {
  margin-top: 0;
  font-size: 38rpx;
  color: #1f2329;
}

.page-shell--home .hero-subtitle {
  width: 88%;
  margin-top: 12rpx;
  font-size: 18rpx;
  line-height: 1.62;
  color: #1f2a21;
}

.page-shell--home .hero-meta {
  margin-top: 18rpx;
}

.page-shell--home .hero-chip {
  padding: 8rpx 14rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1.5rpx solid rgba(255, 255, 255, 0.32);
  color: #1f2329;
  font-size: 17rpx;
}

.invite-panel {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.24);
  background: transparent;
  border-radius: 0;
  border: none;
  box-shadow: none;
}

.invite-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.invite-label {
  font-size: 17rpx;
  letter-spacing: 1rpx;
  color: #1f2329;
  font-weight: 600;
}

.invite-note {
  margin-top: 8rpx;
  font-size: 17rpx;
  line-height: 1.58;
  color: #1f2a21;
}

.invite-code {
  min-width: 164rpx;
  padding: 12rpx 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.56);
  text-align: center;
  font-size: 20rpx;
  font-weight: 700;
  color: #1f2329;
}

.invite-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 18rpx;
}

.hero-sub-btn,
.hero-main-btn {
  flex: 1;
  min-height: 68rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 800;
}

.hero-sub-btn {
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.56);
  color: #1f2329;
}

.hero-main-btn {
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.56);
  color: #0f8a4b;
  box-shadow: none;
}

.submit-sheet {
  margin-top: 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.7);
  box-shadow: 0 12rpx 28rpx rgba(7, 193, 96, 0.12);
  animation: panelRise 420ms ease both;
}

.submit-sheet::before {
  display: none;
}

.submit-sheet .section-title {
  font-size: 25rpx;
  line-height: 1.24;
  color: #2f2926;
}

.submit-sheet .section-desc {
  font-size: 18rpx;
  color: #786a66;
}

.sheet-block {
  margin-top: 18rpx;
  padding: 20rpx 18rpx;
  border: 1rpx solid rgba(31, 35, 41, 0.7);
  border-radius: 20rpx;
  background: #ffffff;
  box-shadow: none;
}

.sheet-block--task {
  margin-top: 22rpx;
}

.sheet-block--platform {
  margin-top: 16rpx;
}

.sheet-block--info {
  margin-top: 16rpx;
}

.sheet-block-head {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.sheet-step,
.upload-step {
  min-height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(7, 193, 96, 0.12);
  color: #0f8a4b;
  font-size: 17rpx;
  font-weight: 700;
  letter-spacing: 1.2rpx;
}

.sheet-label {
  font-size: 22rpx;
  font-weight: 700;
  color: #2f2926;
}

.sheet-block--task .sheet-label {
  font-size: 24rpx;
}

.service-list {
  display: flex;
  align-items: stretch;
  gap: 12rpx;
  margin-top: 18rpx;
}

.service-row {
  position: relative;
  flex: 1 1 0;
  min-width: 0;
  min-height: 166rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 20rpx 16rpx 16rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.48);
  box-shadow: none;
}

.service-row--aigc_detect {
  background: #ffffff;
}

.service-row--rewrite {
  background: #ffffff;
}

.service-row--dedup {
  background: #ffffff;
}

.service-row::before {
  display: none;
}

.service-row.active {
  background: linear-gradient(180deg, #18c96c 0%, #07c160 52%, #06b45a 100%);
  border-color: rgba(6, 150, 76, 0.34);
  box-shadow: 0 12rpx 24rpx rgba(7, 193, 96, 0.2);
}

.service-headline {
  display: block;
}

.service-main {
  display: block;
}

.service-name {
  padding-right: 0;
  font-size: 24rpx;
  line-height: 1.32;
  font-weight: 700;
  color: #2f2926;
}

.service-note {
  margin-top: 8rpx;
  font-size: 17rpx;
  line-height: 1.56;
  color: #786a66;
}

.service-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  padding-top: 16rpx;
}

.service-badge {
  min-height: 36rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.56);
  color: #7d6e6a;
  font-size: 17rpx;
  font-weight: 700;
}

.service-badge.active {
  background: rgba(255, 255, 255, 0.8);
  border-color: rgba(255, 255, 255, 0.34);
  color: #1f2329;
}

.service-arrow {
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid rgba(47, 41, 38, 0.42);
  border-right: 2rpx solid rgba(47, 41, 38, 0.42);
  transform: rotate(45deg);
}

.service-row.active .service-arrow {
  border-top-color: #1f2329;
  border-right-color: #1f2329;
}

.submit-sheet .helper-text {
  font-size: 17rpx;
  line-height: 1.64;
  color: #7b6e6a;
}

.segment-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: 18rpx 0 0;
}

.segment-chip {
  min-height: 66rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.42);
  color: #6e615d;
  font-size: 18rpx;
  font-weight: 600;
  box-shadow: none;
}

.segment-chip.active {
  background: linear-gradient(180deg, #18c96c 0%, #07c160 52%, #06b45a 100%);
  border-color: rgba(6, 150, 76, 0.34);
  color: #1f2329;
  box-shadow: 0 10rpx 20rpx rgba(7, 193, 96, 0.18);
}

.upload-panel {
  margin-top: 24rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.7);
  box-shadow: none;
}

.upload-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 14rpx;
}

.upload-title {
  margin-top: 0;
}

.upload-tip {
  padding: 6rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(7, 193, 96, 0.12);
  font-size: 16rpx;
  line-height: 1.4;
  color: #0f8a4b;
}

.upload-file {
  margin-top: 16rpx;
  min-height: 88rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  background: #ffffff;
  border: 1rpx solid rgba(31, 35, 41, 0.28);
  font-size: 20rpx;
  line-height: 1.5;
  color: #9a8b86;
  word-break: break-all;
}

.upload-file--selected {
  background: #f5fff9;
  border-color: rgba(7, 193, 96, 0.5);
  color: #2f2926;
  font-weight: 700;
}

.upload-action {
  margin-top: 18rpx;
  background: linear-gradient(180deg, #18c36b 0%, #07c160 100%) !important;
  color: #ffffff !important;
  border: none !important;
  box-shadow: 0 12rpx 22rpx rgba(7, 193, 96, 0.16) !important;
}

.field-stack {
  display: flex;
  flex-direction: column;
  gap: 0;
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(31, 35, 41, 0.24);
  background: #ffffff;
}

.field {
  margin-top: 0;
}

.field + .field {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(47, 41, 38, 0.1);
}

.field-label {
  margin-bottom: 10rpx;
  font-size: 17rpx;
  color: #7f706c;
}

.text-input {
  min-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(31, 35, 41, 0.24);
  background: #ffffff;
  font-size: 20rpx;
}

.button-group--single {
  margin: 22rpx 0 0;
}

.button-group--single .button-item {
  flex: 1 1 100%;
  margin: 0;
}

.page-shell--home .primary-btn,
.page-shell--home .secondary-btn {
  min-height: 76rpx;
  border-radius: 18rpx;
  font-size: 21rpx;
}

.page-shell--home .primary-btn {
  background: linear-gradient(180deg, #18c36b 0%, #07c160 100%);
  color: #ffffff;
  box-shadow: 0 14rpx 24rpx rgba(7, 193, 96, 0.18);
}

.page-shell--home .secondary-btn {
  background: #ffffff;
  color: #3a322f;
  border: 1rpx solid rgba(31, 35, 41, 0.56);
  box-shadow: none;
}

.submit-next-step {
  margin-top: 16rpx;
  padding: 14rpx 0 0;
  border-top: 1rpx dashed rgba(47, 41, 38, 0.18);
  border-radius: 0;
  background: transparent;
  font-size: 17rpx;
  color: #7b6e6a;
}

@keyframes heroRise {
  from {
    transform: translateY(14rpx);
    opacity: 0;
  }

  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@keyframes panelRise {
  from {
    transform: translateY(12rpx);
    opacity: 0;
  }

  to {
    transform: translateY(0);
    opacity: 1;
  }
}
