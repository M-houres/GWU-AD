<view class="container">
  <view class="card">
    <view class="row">
      <view class="title">格物学术</view>
      <view class="muted">积分：{{ user.credits || 0 }}</view>
    </view>
    <view class="muted gap-12">稳定、简洁、可追踪的论文处理工作台。</view>
  </view>

  <view class="card gap-16">
    <view class="row">
      <view class="title" style="font-size: 30rpx;">系统公告</view>
      <view class="muted">v{{ notice.version }}</view>
    </view>
    <view class="gap-12">{{ notice.title || "系统公告" }}</view>
    <view class="muted gap-12">{{ notice.content || "暂无公告内容" }}</view>
  </view>

  <view class="card gap-16">
    <view class="title" style="font-size: 30rpx;">核心功能</view>
    <view class="gap-16">
      <view class="row" wx:for="{{ features }}" wx:key="taskType">
        <view>
          <view>{{ item.title }}</view>
          <view class="muted">{{ item.desc }}</view>
        </view>
        <button class="btn-secondary" data-task="{{ item.taskType }}" bindtap="onTapFeature">进入</button>
      </view>
    </view>
  </view>

  <view class="card gap-16">
    <view class="title" style="font-size: 30rpx;">积分与支付</view>
    <view class="muted gap-12">购买积分后可直接用于三大核心任务。</view>
    <button class="btn-primary gap-16" bindtap="onGoPay">立即充值</button>
  </view>
</view>
