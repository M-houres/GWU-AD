<view class="page-shell page-shell--home">
  <view class="content-stack">
    <view class="hero-panel home-hero">
      <view class="hero-title">{{ runtimeCopy.home.hero_title }}</view>
      <view class="hero-subtitle">{{ runtimeCopy.home.hero_subtitle }}</view>

      <view class="hero-meta">
        <view class="hero-chip">{{ creditChipText }}</view>
        <view class="hero-chip">{{ quotaChipText }}</view>
      </view>

      <view class="invite-panel" wx:if="{{ !guestMode }}">
        <view class="invite-head">
          <view>
            <view class="invite-label">{{ runtimeCopy.home.invite_label }}</view>
            <view class="invite-note">{{ runtimeCopy.home.invite_note }}</view>
          </view>
          <view class="invite-code">{{ inviteInfo.inviteCode || "待生成" }}</view>
        </view>

        <view class="invite-actions">
          <button class="hero-sub-btn" hover-class="is-press-btn" bindtap="onCopyInviteCode">{{ runtimeCopy.home.copy_invite_button_text }}</button>
          <button class="hero-main-btn" hover-class="is-press-btn" open-type="share">{{ runtimeCopy.home.share_button_text }}</button>
        </view>
      </view>
    </view>

    <view class="surface submit-sheet">
      <view class="section-head">
        <view class="section-copy">
          <view class="section-kicker">任务工作区</view>
          <view class="section-title">{{ quotaPanelTitle }}</view>
          <view class="section-desc">{{ quotaPanelDesc }}</view>
        </view>
      </view>

      <view class="sheet-block sheet-block--task">
        <view class="sheet-block-head">
          <view class="sheet-step">第一步</view>
          <view class="sheet-label">选择服务</view>
        </view>
        <view class="service-list">
          <view
            class="service-row service-row--{{ item.value }} {{ selectedTaskType === item.value ? 'active' : '' }}"
            wx:for="{{ taskOptions }}"
            wx:key="value"
            data-value="{{ item.value }}"
            bindtap="onSelectTaskType"
            hover-class="is-press-card"
            hover-stay-time="70"
          >
            <view class="service-headline">
              <view class="service-main">
                <view class="service-name">{{ item.label }}</view>
                <view class="service-note">{{ item.note }}</view>
              </view>
            </view>
            <view class="service-foot">
              <view class="service-badge {{ selectedTaskType === item.value ? 'active' : '' }}">
                {{ selectedTaskType === item.value ? "已选" : item.badge }}
              </view>
              <view class="service-arrow"></view>
            </view>
          </view>
        </view>
        <view class="helper-text">{{ selectedTaskMeta.helper }}</view>
      </view>

      <view class="sheet-block sheet-block--platform">
        <view class="sheet-block-head">
          <view class="sheet-step">第二步</view>
          <view class="sheet-label">选择平台</view>
        </view>
        <view class="segment-row">
          <view
            class="segment-chip {{ selectedPlatform === item.value ? 'active' : '' }}"
            wx:for="{{ platformOptions }}"
            wx:key="value"
            data-value="{{ item.value }}"
            bindtap="onSelectPlatform"
            hover-class="is-press-pill"
          >
            {{ item.label }}
          </view>
        </view>
        <view class="helper-text">{{ selectedPlatformMeta.desc }}</view>
      </view>

      <view class="upload-panel">
        <view class="upload-head">
          <view class="sheet-block-head">
            <view class="sheet-step">第三步</view>
            <view class="sheet-label upload-title">上传文件</view>
          </view>
          <view class="upload-tip">优先从微信聊天记录中选择</view>
        </view>
        <view class="upload-file {{ paperName ? 'upload-file--selected' : '' }}">
          {{ paperName || "尚未选择文件" }}
        </view>
        <view class="helper-text">{{ uploadRuleText }}</view>
        <view class="helper-text" wx:if="{{ paperName && !paperTitle }}">选择文件后会自动读取文件名作为篇名。</view>
        <button class="secondary-btn upload-action" hover-class="is-press-btn" bindtap="onChooseFile">选择微信文件</button>
      </view>

      <view class="sheet-block sheet-block--info">
        <view class="sheet-block-head">
          <view class="sheet-step">第四步</view>
          <view class="sheet-label">信息填写</view>
        </view>

        <view class="field-stack">
          <view class="field">
            <view class="field-label">篇名</view>
            <input
              class="text-input"
              placeholder="请输入论文篇名"
              maxlength="300"
              value="{{ paperTitle }}"
              bindinput="onInputPaperTitle"
            />
          </view>

          <view class="field">
            <view class="field-label">作者</view>
            <input
              class="text-input"
              placeholder="请输入作者姓名，多位作者可用分号分隔"
              maxlength="200"
              value="{{ authors }}"
              bindinput="onInputAuthors"
            />
          </view>
        </view>
      </view>

      <view class="button-group button-group--single">
        <view class="button-item">
          <button
            class="primary-btn"
            loading="{{ submitting }}"
            disabled="{{ submitting }}"
            bindtap="onSubmitTask"
            hover-class="is-press-btn"
          >
            {{ submitting ? "提交中..." : "提交任务" }}
          </button>
        </view>
      </view>
      <view class="helper-text submit-next-step">第五步 已提交任务：提交后会自动进入记录页查看进度。</view>
    </view>
  </view>
</view>
