<view class="container">
  <view class="card">
    <view class="title" style="font-size: 30rpx;">任务类型</view>
    <view class="gap-16">
      <view class="chip {{ selectedTaskType === 'rewrite' ? 'active' : '' }}" data-value="rewrite" bindtap="onSelectTaskType">学术润色</view>
      <view class="chip {{ selectedTaskType === 'dedup' ? 'active' : '' }}" data-value="dedup" bindtap="onSelectTaskType">降重复率</view>
      <view class="chip {{ selectedTaskType === 'aigc_detect' ? 'active' : '' }}" data-value="aigc_detect" bindtap="onSelectTaskType">AIGC 检测</view>
    </view>
  </view>

  <view class="card gap-16">
    <view class="title" style="font-size: 30rpx;">平台选择</view>
    <view class="gap-16">
      <view class="chip {{ selectedPlatform === 'cnki' ? 'active' : '' }}" data-value="cnki" bindtap="onSelectPlatform">知网</view>
      <view class="chip {{ selectedPlatform === 'vip' ? 'active' : '' }}" data-value="vip" bindtap="onSelectPlatform">维普</view>
      <view class="chip {{ selectedPlatform === 'paperpass' ? 'active' : '' }}" data-value="paperpass" bindtap="onSelectPlatform">PaperPass</view>
    </view>
  </view>

  <view class="card gap-16">
    <view class="title" style="font-size: 30rpx;">上传文档</view>
    <view class="muted gap-12">当前仅演示主文档上传，支持 `.docx` / `.pdf` / `.txt`（按任务类型会有后端校验）。</view>
    <view class="input gap-16">{{ paperName || "尚未选择文件" }}</view>
    <view class="row gap-16">
      <button class="btn-secondary" bindtap="onChooseFile">选择文件</button>
      <button class="btn-primary" loading="{{ submitting }}" disabled="{{ submitting || !paperPath }}" bindtap="onSubmitTask">
        {{ submitting ? "提交中..." : "提交任务" }}
      </button>
    </view>
  </view>
</view>

