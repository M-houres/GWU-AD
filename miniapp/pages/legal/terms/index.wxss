.legal-page{min-height:100vh;background:#f4f8ff;padding:32rpx}
.legal-card{background:#fff;border:2rpx solid rgba(30,91,223,.14);border-radius:24rpx;padding:32rpx;display:flex;flex-direction:column;gap:24rpx;box-shadow:0 10rpx 24rpx rgba(30,91,223,.08)}
.legal-title{font-size:36rpx;font-weight:700;color:#17385f}
.legal-text{font-size:28rpx;line-height:1.8;color:#4e6886}
