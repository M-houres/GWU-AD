<view class="container">
  <view class="card">
    <view class="title" style="font-size: 30rpx;">积分套餐</view>
    <view class="muted gap-12">{{ paymentTestMode ? "当前为测试支付模式" : "当前为正式支付模式" }}</view>
  </view>

  <view class="card gap-16">
    <view class="title" style="font-size: 30rpx;">支付方式</view>
    <view class="provider-wrap gap-16">
      <view
        class="chip {{ selectedProvider === item.value ? 'active' : '' }}"
        wx:for="{{ providers }}"
        wx:key="value"
        data-value="{{ item.value }}"
        bindtap="onSelectProvider"
      >
        {{ item.label }}
      </view>
    </view>
  </view>

  <view class="card gap-16" wx:for="{{ packages }}" wx:key="name">
    <view class="row">
      <view>{{ item.name }}</view>
      <view class="muted">¥{{ item.price }}</view>
    </view>
    <view class="muted gap-12">{{ item.description || "适用于论文处理与检测任务" }}</view>
    <view class="muted gap-12">积分：{{ item.credits }}</view>
    <button class="btn-primary gap-16" loading="{{ creating }}" data-name="{{ item.name }}" bindtap="onCreateOrder">创建订单</button>
  </view>

  <view class="card gap-16" wx:if="{{ orderNo }}">
    <view class="title" style="font-size: 30rpx;">当前订单</view>
    <view class="muted gap-12">订单号：{{ orderNo }}</view>
    <view class="muted gap-12">渠道：{{ orderProvider || '-' }}</view>
    <view class="muted gap-12">状态：{{ orderStatusText }}</view>
    <view class="muted gap-12">剩余：{{ remainSeconds }} 秒</view>
    <image wx:if="{{ qrcodeDataUrl }}" src="{{ qrcodeDataUrl }}" mode="aspectFit" style="width: 280rpx; height: 280rpx;" />

    <view class="row gap-16">
      <button class="btn-secondary" bindtap="onRefreshOrder">刷新状态</button>
      <button wx:if="{{ orderProvider === 'wechat' && paymentParams }}" class="btn-primary" loading="{{ paying }}" bindtap="onStartWechatPay">立即支付</button>
      <button wx:else class="btn-primary" bindtap="onConfirmPaid">我已支付</button>
    </view>
  </view>
</view>
