.page-shell--records {
  padding-top: 22rpx;
}

.page-shell--records .content-stack {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.records-hero {
  padding: 28rpx 24rpx 22rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #18c96c 0%, #07c160 52%, #06b45a 100%);
  border: 2rpx solid rgba(6, 150, 76, 0.34);
  box-shadow: 0 12rpx 24rpx rgba(7, 193, 96, 0.2);
  color: #1f2329;
}

.records-hero::before,
.records-hero::after {
  display: none;
}

.records-hero .hero-title {
  margin-top: 0;
  font-size: 32rpx;
  color: #1f2329;
}

.records-hero .hero-subtitle {
  width: 92%;
  margin-top: 10rpx;
  font-size: 18rpx;
  line-height: 1.6;
  color: #1f2a21;
}

.records-hero .hero-meta {
  margin-top: 18rpx;
}

.records-hero .hero-chip {
  padding: 8rpx 14rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1.5rpx solid rgba(255, 255, 255, 0.32);
  color: #1f2329;
  font-size: 17rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin: 0 0 4rpx;
}

.filter-pill {
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid rgba(47, 41, 38, 0.18);
  color: #6f615d;
  font-size: 18rpx;
  box-shadow: none;
}

.filter-pill.active {
  background: rgba(238, 249, 242, 0.98);
  border-color: rgba(7, 193, 96, 0.64);
  color: #0f8a4b;
  box-shadow: 0 0 0 3rpx rgba(7, 193, 96, 0.1);
}

.filter-count {
  margin-left: 8rpx;
  opacity: 0.7;
}

.records-loading {
  margin-top: 0;
  padding: 22rpx 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(47, 41, 38, 0.2);
  box-shadow: none;
}

.page-shell--records .loading-orbit {
  background: rgba(7, 193, 96, 0.1);
}

.page-shell--records .loading-dot {
  background: #07c160;
}

.page-shell--records .loading-title {
  color: #2f2926;
}

.page-shell--records .loading-desc {
  color: #786a66;
}

.page-shell--records .skeleton-card {
  background: linear-gradient(90deg, rgba(247, 241, 235, 0.96) 25%, rgba(255, 253, 250, 1) 50%, rgba(247, 241, 235, 0.96) 75%);
}

.page-shell--records .skeleton-line {
  background: rgba(47, 41, 38, 0.08);
}

.record-card {
  position: relative;
  overflow: hidden;
  margin-top: 0;
  padding: 22rpx 20rpx 20rpx 26rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(47, 41, 38, 0.2);
  box-shadow: 0 8rpx 18rpx rgba(76, 58, 54, 0.03);
  animation: recordRise 320ms ease both;
}

.record-card::after {
  display: none;
}

.record-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 18rpx;
  bottom: 18rpx;
  width: 7rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #07c160 0%, rgba(7, 193, 96, 0.18) 100%);
}

.record-head {
  align-items: flex-start;
  gap: 12rpx;
}

.record-copy {
  flex: 1;
  min-width: 0;
  padding-right: 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-title {
  font-size: 21rpx;
  line-height: 1.38;
  font-weight: 700;
  color: #2f2926;
}

.record-meta {
  margin-top: 0;
  font-size: 16rpx;
  line-height: 1.52;
  color: #786a66;
}

.record-mini-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
  padding-top: 14rpx;
  border-top: 1rpx solid rgba(47, 41, 38, 0.1);
}

.record-mini-pill {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1.5rpx solid rgba(47, 41, 38, 0.18);
  color: #7a6d69;
  font-size: 15rpx;
}

.record-actions {
  display: flex;
  gap: 10rpx;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(47, 41, 38, 0.1);
}

.record-action-item {
  flex: 1;
}

.record-actions .primary-btn,
.record-actions .secondary-btn {
  min-height: 62rpx;
  border-radius: 16rpx;
  font-size: 18rpx;
}

.record-actions .primary-btn {
  background: linear-gradient(180deg, #18c36b 0%, #07c160 100%);
  color: #ffffff;
  box-shadow: none;
}

.record-actions .secondary-btn {
  background: #ffffff;
  color: #362f2d;
  border: 2rpx solid rgba(47, 41, 38, 0.18);
  box-shadow: none;
}

.page-shell--records .status-badge {
  min-height: 36rpx;
  padding: 0 14rpx;
  font-size: 17rpx;
}

.page-shell--records .surface {
  background: #ffffff;
  border: 2rpx solid rgba(47, 41, 38, 0.2);
  box-shadow: none;
}

.page-shell--records .surface::before {
  display: none;
}

.page-shell--records .section-title {
  font-size: 22rpx;
  color: #2f2926;
}

.page-shell--records .section-desc {
  font-size: 18rpx;
  color: #786a66;
}

.page-shell--records .report-grid {
  gap: 10rpx;
  margin: 16rpx 0 0;
}

.page-shell--records .report-card {
  margin: 0;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid rgba(47, 41, 38, 0.2);
  box-shadow: none;
}

.page-shell--records .report-label {
  font-size: 17rpx;
  color: #81736e;
}

.page-shell--records .report-value {
  font-size: 22rpx;
  color: #2f2926;
}

.result-block {
  height: 340rpx;
  padding: 20rpx;
  border-radius: 16rpx;
  background: #ffffff;
  border: 2rpx solid rgba(47, 41, 38, 0.2);
}

.page-shell--records .empty-state {
  margin-top: 0;
  background: #ffffff;
  border: 2rpx dashed rgba(7, 193, 96, 0.18);
}

@keyframes recordRise {
  from {
    transform: translateY(10rpx);
    opacity: 0;
  }

  to {
    transform: translateY(0);
    opacity: 1;
  }
}
