<view class="container">
  <view class="card" wx:if="{{ !task.id }}">
    <view class="muted">任务不存在或已删除。</view>
  </view>

  <view class="card" wx:if="{{ task.id }}">
    <view class="row">
      <view class="title" style="font-size: 30rpx;">任务 #{{ task.id }}</view>
      <view class="muted">{{ statusText }}</view>
    </view>
    <view class="muted gap-12">{{ task.task_type }} / {{ task.platform }}</view>
    <view class="muted gap-12">文件：{{ task.source_filename || "-" }}</view>
    <view class="muted gap-12">字符数：{{ task.char_count || 0 }} · 扣费：{{ task.cost_credits || 0 }}</view>
    <view class="muted gap-12" wx:if="{{ task.error_message }}">错误：{{ task.error_message }}</view>
  </view>

  <view class="card gap-16" wx:if="{{ task.id }}">
    <view class="title" style="font-size: 30rpx;">结果信息</view>
    <view class="muted gap-12">{{ resultText }}</view>
    <view class="row gap-16">
      <button class="btn-secondary" bindtap="onRefresh">刷新</button>
      <button class="btn-primary" bindtap="onDownloadResult">下载结果</button>
    </view>
  </view>
</view>
