.partner-stats {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.partner-stat {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(7, 193, 96, 0.14);
}

.partner-stat-label {
  font-size: 18rpx;
  color: #7e706d;
}

.partner-stat-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #544746;
}

.partner-link-card,
.partner-child-list {
  margin-top: 18rpx;
  display: grid;
  gap: 16rpx;
}

.partner-link-item,
.partner-child-card {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 2rpx solid rgba(7, 193, 96, 0.14);
}

.partner-link-label {
  font-size: 18rpx;
  color: #0f8a4b;
  font-weight: 600;
}

.partner-link-value {
  margin: 10rpx 0 16rpx;
  font-size: 18rpx;
  line-height: 1.6;
  color: #7e706d;
  word-break: break-all;
}

.partner-child-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.partner-child-actions {
  display: grid;
  gap: 12rpx;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  margin-top: 16rpx;
}
