.login-screen {
  position: relative;
  min-height: 100vh;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
  padding: 40rpx 32rpx calc(44rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #07c160 0%, #09b65b 52%, #0da85a 100%);
}

.login-bg-orb {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
  filter: blur(8rpx);
}

.login-bg-orb--top {
  top: 40rpx;
  right: -56rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.18);
}

.login-bg-orb--bottom {
  left: -48rpx;
  bottom: 220rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(7, 193, 96, 0.12);
}

.login-hero {
  position: relative;
  z-index: 1;
  flex: 1 1 auto;
  min-height: 0;
  padding: 18vh 0 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.login-hero-top {
  display: flex;
  align-items: center;
  justify-content: center;
}

.login-brand-copy {
  min-width: 0;
  text-align: center;
}

.login-brand-name {
  font-size: 78rpx;
  line-height: 1.08;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.login-brand-sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.78);
}

.login-sheet {
  position: relative;
  z-index: 2;
  flex: 0 0 auto;
  margin-top: auto;
  padding: 0;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.login-sheet-head {
  display: none;
}

.login-policy {
  margin-top: 0;
  padding-top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 19rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.login-action-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 26rpx;
}

.login-primary-btn,
.login-secondary-btn {
  width: 100%;
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.login-primary-btn {
  background: #ffffff;
  color: #099454;
  box-shadow: 0 18rpx 36rpx rgba(12, 77, 44, 0.18);
}

.login-secondary-btn {
  background: rgba(255, 255, 255, 0.12);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  color: #ffffff;
}

.login-primary-btn[disabled],
.login-secondary-btn[disabled] {
  opacity: 0.58;
  box-shadow: none;
}
