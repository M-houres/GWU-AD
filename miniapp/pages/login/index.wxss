.login-screen {
  position: relative;
  min-height: 100vh;
  min-height: 100svh;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  overflow: hidden;
  padding: 40rpx 32rpx calc(44rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #6ca0ff 0%, #4584fa 38%, #1e5bdf 100%);
}

.login-bg-orb {
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
  filter: blur(8rpx);
}

.login-bg-orb--top {
  top: 40rpx;
  right: -56rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.18);
}

.login-bg-orb--bottom {
  left: -48rpx;
  bottom: 220rpx;
  width: 180rpx;
  height: 180rpx;
  background: rgba(255, 255, 255, 0.12);
}

.login-hero {
  position: relative;
  z-index: 1;
  flex: 1 1 auto;
  min-height: 0;
  padding: 18vh 0 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-start;
}

.login-hero-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.login-brand-logo-shell {
  width: 284rpx;
  height: 284rpx;
  margin-bottom: 10rpx;
  border-radius: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 18rpx 42rpx rgba(8, 32, 92, 0.18);
}

.login-brand-logo {
  width: 252rpx;
  height: 252rpx;
  filter: drop-shadow(0 10rpx 22rpx rgba(10, 34, 92, 0.12));
}

.login-brand-copy {
  min-width: 0;
  text-align: center;
}

.login-brand-name {
  font-size: 78rpx;
  line-height: 1.08;
  font-weight: 800;
  color: #ffffff;
  letter-spacing: 2rpx;
}

.login-sheet {
  position: relative;
  z-index: 2;
  flex: 0 0 auto;
  margin-top: auto;
  padding: 0;
  border-radius: 0;
  background: transparent;
  border: none;
  box-shadow: none;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.login-sheet-head {
  display: none;
}

.login-policy {
  margin-top: 0;
  padding-top: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-size: 19rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
  background: transparent;
  border: 0;
  border-radius: 0;
  min-height: auto;
  width: 100%;
  box-sizing: border-box;
  text-align: center;
}

.login-policy::after {
  border: 0;
}

.login-privacy-btn {
  width: 100%;
  margin-top: 18rpx;
  min-height: 80rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
  color: #ffffff;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.login-privacy-btn::after {
  border: 0;
}

.login-policy-check {
  width: 30rpx;
  height: 30rpx;
  flex: 0 0 30rpx;
  border-radius: 8rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.92);
  background: rgba(255, 255, 255, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin-top: 2rpx;
}

.login-policy-check--active {
  background: #ffffff;
  border-color: #ffffff;
}

.login-policy-check__icon {
  color: #1e5bdf;
  font-size: 20rpx;
  line-height: 1;
  font-weight: 800;
}

.login-policy-text {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 4rpx;
}

.login-policy-link {
  color: #ffffff;
  font-weight: 700;
  text-decoration: underline;
}

.login-status-card {
  margin: 0 0 22rpx;
  padding: 22rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.16);
  border: 1rpx solid rgba(255, 255, 255, 0.26);
  backdrop-filter: blur(10rpx);
}

.login-status-title {
  font-size: 24rpx;
  font-weight: 800;
  color: #ffffff;
}

.login-status-desc {
  margin-top: 10rpx;
  font-size: 18rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.82);
}

.login-mode-tip {
  margin: 0 0 18rpx;
  text-align: center;
  font-size: 20rpx;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.88);
}

.login-action-stack {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 26rpx;
}

.login-primary-btn,
.login-secondary-btn {
  width: 100%;
  min-height: 92rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
}

.login-primary-btn {
  background: #ffffff;
  color: #1e5bdf;
  box-shadow: 0 18rpx 36rpx rgba(14, 45, 110, 0.18);
}

.login-secondary-btn {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.28);
  color: #ffffff;
}

.login-primary-btn[disabled],
.login-secondary-btn[disabled] {
  opacity: 0.58;
  box-shadow: none;
}
