# app
APP_NAME=格物学术
APP_ENV=prod
APP_HOST=0.0.0.0
APP_PORT=8000
JWT_SECRET=replace_with_strong_jwt_secret
JWT_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30
AUTH_COOKIE_SECURE=true
AUTH_COOKIE_SAMESITE=lax
USER_REFRESH_COOKIE_NAME=gw_user_refresh
ADMIN_REFRESH_COOKIE_NAME=gw_admin_refresh
CORS_ALLOW_ORIGINS=https://your-domain.com,https://www.your-domain.com

# db
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=wuhongai
MYSQL_PASSWORD=replace_with_mysql_app_password
MYSQL_ROOT_PASSWORD=replace_with_mysql_root_password
MYSQL_DATABASE=wuhongai
SQLITE_PATH=wuhongai.db
DB_FALLBACK_SQLITE=false

# redis / celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# business
INITIAL_CREDITS=5000
REFERRAL_REGISTER_INVITER_CREDITS=500
REFERRAL_REGISTER_INVITEE_BONUS=500
MAX_CODE_RETRY=3
PHONE_LOCK_MINUTES=5
AUTH_SEND_CODE_IP_1H_LIMIT=30
AUTH_LOGIN_IP_10M_LIMIT=120
AUTH_RETURN_DEBUG_CODE=false
ADMIN_LOGIN_IP_ALLOWLIST=
ADMIN_LOGIN_IP_10M_LIMIT=30
ADMIN_LOGIN_USER_10M_LIMIT=10
SMS_API_KEY=
SMS_GATEWAY_URL=
PAYMENT_SIGN_SECRET=replace_with_strong_payment_sign_secret
PAYMENT_CALLBACK_TTL_SECONDS=900
PAYMENT_TEST_MODE=false
FRONTEND_BASE_URL=https://your-domain.com
ALGORITHM_PACKAGE_ROOT=
ALGORITHM_PACKAGE_MAX_MB=200
LLM_ENABLED_DEFAULT=false
LLM_API_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=25
CELERY_LOCAL_FALLBACK_ENABLED=false

# admin init
ADMIN_INIT_USERNAME=admin
ADMIN_INIT_PASSWORD=replace_with_strong_admin_password

# frontend
VITE_API_BASE_URL=/api/v1
VITE_ENABLE_WECHAT_LOGIN=false
VITE_PAYMENT_TEST_MODE=false
